# Copy this file to .env.telegram and fill values.
TELEGRAM_BOT_TOKEN=123456789:replace_with_bot_token
# Preferred target value:
# - Channel username: @your_channel_name
# - Channel/supergroup numeric id: -100xxxxxxxxxx
TELEGRAM_TARGET=@replace_with_channel_username
# Optional fallback (kept for compatibility)
TELEGRAM_CHAT_ID=
# Optional topic id if sending into a forum topic
TELEGRAM_MESSAGE_THREAD_ID=
CHECK_URL=https://tischreservierung-oktoberfest.de/shop/?swoof=1&pa_festzelt=fischer-vroni
